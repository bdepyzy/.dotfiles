#!/usr/bin/env bash
set -euo pipefail

sound_dir="${CS2_REACTION_DIR:-$HOME/.local/share/cs2-reactions}"
default_sound="$sound_dir/sounds__vo__agents__jungle_fem__aff1_cheer_08.wav"
title=""
body=""

if [[ "${1:-}" == "--notify" ]]; then
  title="${2:-CS2 reaction}"
  body="${3:-}"
fi

if [[ -n "${CS2_REACTION_SOUND:-}" && -f "$CS2_REACTION_SOUND" ]]; then
  sound="$CS2_REACTION_SOUND"
else
  sound="$(find "$sound_dir" -type f -name '*.wav' | shuf -n 1)"
  if [[ -z "$sound" && -f "$default_sound" ]]; then
    sound="$default_sound"
  fi
fi

printf '%s selected %s\n' "$(date -Is)" "$(basename "$sound")" >> "$HOME/.local/state/cs2-reaction.log"

if [[ -n "$title" ]] && command -v notify-send >/dev/null 2>&1; then
  notify-send -a "CS2 Reaction" -i "$HOME/.config/waybar/icons/counterstrike-player.png" "$title" "$body" >/dev/null 2>&1 || true
fi

if command -v pw-play >/dev/null 2>&1; then
  pw-play "$sound" >/dev/null 2>&1
elif command -v paplay >/dev/null 2>&1; then
  paplay "$sound" >/dev/null 2>&1
elif command -v aplay >/dev/null 2>&1; then
  aplay "$sound" >/dev/null 2>&1
fi
